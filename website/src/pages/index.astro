---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import DynamicBackground from '../components/DynamicBackground.astro';
import { GitHubStars } from '../components/GitHubStars';
import { InstallCommand } from '../components/InstallCommand';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Gatelet — The Permission Layer for AI Agents">
  <!-- ═══ Global background ═══ -->
  <DynamicBackground />
  <div class="fixed inset-0 -z-[9] pointer-events-none hero-glow" aria-hidden="true"></div>

  <!-- ═══ Sticky navigation ═══ -->
  <nav id="main-nav" class="sticky top-0 z-50 border-b border-transparent">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
      <a href="/" class="flex items-center gap-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-indigo-600 shadow-lg shadow-indigo-500/20">
          <Logo class="h-4.5 w-4.5 text-white" />
        </div>
        <span class="font-[Fraunces] text-lg italic text-zinc-900 dark:text-white">Gatelet</span>
      </a>
      <div class="flex items-center gap-3">
        <a href="/getting-started/introduction/" class="text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">
          Docs
        </a>
        <a href="https://github.com/hannesill/gatelet" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white hidden sm:block">
          GitHub
        </a>
        <div class="hidden sm:block">
          <GitHubStars client:load />
        </div>
        <ThemeToggle client:load />
      </div>
    </div>
  </nav>

  <main class="relative z-10">

    <!-- ═══ HERO ═══ -->
    <section class="flex flex-col items-center px-6 pt-16 pb-8 text-center sm:pt-24">
      <!-- Badge -->
      <div class="animate-in mb-8 inline-flex items-center gap-2.5 rounded-full bg-indigo-500/8 px-4 py-1.5 text-xs font-semibold text-indigo-700 ring-1 ring-indigo-500/15 dark:bg-indigo-500/10 dark:text-indigo-300 dark:ring-indigo-500/20">
        <div class="h-1.5 w-1.5 rounded-full bg-indigo-500 dot-pulse"></div>
        Open Source &middot; Self-Hosted
      </div>

      <!-- Heading with gradient -->
      <h1 class="animate-in stagger-1 gradient-text font-[Fraunces] text-6xl font-bold italic tracking-tight sm:text-8xl">
        Gatelet
      </h1>

      <!-- Subtitle -->
      <p class="animate-in stagger-2 mt-6 text-lg font-semibold text-zinc-700 dark:text-zinc-300 sm:text-xl">
        Fine-grained account access for your agents.
      </p>

      <!-- Description -->
      <p class="animate-in stagger-3 mx-auto mt-4 max-w-xl text-base leading-relaxed text-zinc-500 dark:text-zinc-400">
        A self-hosted MCP proxy that gives you full control over how your
        agents can access your mails and calendars (and soon other online accounts).
      </p>

      <!-- OS-aware install command -->
      <div class="animate-in stagger-4 w-full flex justify-center">
        <InstallCommand client:load />
      </div>

      <!-- CTAs -->
      <div class="animate-in stagger-5 mt-8 flex flex-col items-center gap-3 sm:flex-row">
        <a href="/getting-started/introduction/" class="flex w-full items-center justify-center gap-2 rounded-2xl bg-zinc-900 px-8 py-3.5 text-sm font-bold text-white transition-all hover:bg-zinc-800 active:scale-[0.97] dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200 sm:w-auto">
          Get Started
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="https://github.com/hannesill/gatelet" target="_blank" rel="noopener noreferrer" class="flex w-full items-center justify-center gap-2 rounded-2xl bg-white/50 px-8 py-3.5 text-sm font-bold text-zinc-900 ring-1 ring-zinc-200 backdrop-blur-md transition-all hover:bg-white/80 active:scale-[0.97] dark:bg-white/5 dark:text-white dark:ring-white/10 dark:hover:bg-white/10 sm:w-auto">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>

      <!-- Demo video placeholder -->
      <div class="animate-in stagger-6 relative mx-auto mt-16 w-full max-w-4xl sm:mt-20">
        <!-- Glow behind the video frame -->
        <div class="absolute -inset-8 rounded-3xl bg-indigo-500/8 blur-3xl dark:bg-indigo-500/5" aria-hidden="true"></div>

        <!-- Window frame -->
        <div class="relative overflow-hidden rounded-2xl shadow-2xl ring-1 ring-zinc-200 dark:ring-white/10">
          <!-- Browser chrome -->
          <div class="flex items-center gap-2 border-b border-zinc-200 bg-zinc-100 px-4 py-3 dark:border-white/5 dark:bg-zinc-900">
            <div class="flex gap-1.5">
              <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
            </div>
            <div class="mx-auto flex items-center gap-2 rounded-lg bg-white px-4 py-1 text-xs text-zinc-500 shadow-sm dark:bg-white/5 dark:shadow-none">
              <svg class="h-3 w-3 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              localhost:4001
            </div>
          </div>

          <!-- Video content area -->
          <div class="relative flex aspect-video items-center justify-center overflow-hidden bg-gradient-to-br from-indigo-950/80 via-zinc-950 to-purple-950/50">
            <!-- Subtle grid pattern -->
            <div class="absolute inset-0 bg-grid-video opacity-30"></div>

            <!-- Play button -->
            <button class="group relative z-10 flex h-20 w-20 items-center justify-center rounded-full bg-white/10 ring-1 ring-white/20 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:bg-white/15 hover:ring-white/30 cursor-pointer active:scale-105">
              <svg class="h-8 w-8 text-white ml-1 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </button>

            <!-- Label -->
            <p class="absolute bottom-6 text-sm font-medium text-white/30">Demo coming soon</p>
          </div>
        </div>

        <!-- Reflection glow beneath -->
        <div class="mx-auto -mt-4 h-24 w-[60%] rounded-[50%] bg-indigo-500/10 blur-3xl dark:bg-indigo-400/8" aria-hidden="true"></div>
      </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section class="mx-auto mt-28 w-full max-w-5xl px-6 sm:mt-36">
      <div class="reveal text-center">
        <h2 class="font-[Fraunces] text-3xl font-bold italic text-zinc-900 dark:text-white sm:text-4xl">
          How Gatelet works
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-zinc-500 dark:text-zinc-400">
          Gatelet sits between your AI agent and your MCP servers, enforcing fine-grained
          access policies on every single tool call.
        </p>
      </div>

      <!-- Architecture flow -->
      <div class="reveal reveal-delay-1 mt-16 flex items-stretch justify-center gap-3 max-sm:flex-col sm:gap-4">
        <!-- Agent -->
        <div class="glass flex flex-1 flex-col items-center rounded-2xl p-6 text-center sm:p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 dark:bg-blue-500/10">
            <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>
            </svg>
          </div>
          <h3 class="mb-1 text-base font-bold text-zinc-900 dark:text-white">Your AI Agent</h3>
          <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">Claude, GPT, or any MCP&#8209;compatible model</p>
        </div>

        <!-- Arrow right (desktop) / down (mobile) -->
        <div class="flex shrink-0 items-center justify-center text-zinc-300 dark:text-zinc-700">
          <svg class="hidden h-5 w-5 sm:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          <svg class="h-5 w-5 sm:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </div>

        <!-- Gatelet (center, accented) -->
        <div class="glass flex flex-1 flex-col items-center rounded-2xl p-6 text-center ring-2 ring-indigo-500/20 dark:ring-indigo-500/15 sm:p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-600 shadow-lg shadow-indigo-500/20 glow-indigo">
            <Logo class="h-6 w-6 text-white" />
          </div>
          <h3 class="mb-1 text-base font-bold text-zinc-900 dark:text-white">Gatelet Proxy</h3>
          <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">Policy engine, OAuth management, audit logging</p>
        </div>

        <!-- Arrow -->
        <div class="flex shrink-0 items-center justify-center text-zinc-300 dark:text-zinc-700">
          <svg class="hidden h-5 w-5 sm:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          <svg class="h-5 w-5 sm:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </div>

        <!-- Services -->
        <div class="glass flex flex-1 flex-col items-center rounded-2xl p-6 text-center sm:p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 dark:bg-emerald-500/10">
            <svg class="h-6 w-6 text-emerald-600 dark:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>
            </svg>
          </div>
          <h3 class="mb-1 text-base font-bold text-zinc-900 dark:text-white">Your Services</h3>
          <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">Gmail, Outlook Mail, Google Calendar, Outlook Calendar</p>
        </div>
      </div>

      <!-- Filtering demo -->
      <div class="reveal reveal-delay-2 mt-10 overflow-hidden rounded-2xl glass">
        <div class="border-b border-zinc-200 px-6 py-3.5 dark:border-white/5">
          <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">
            Policy enforcement example
          </p>
        </div>
        <div class="divide-y divide-zinc-100 dark:divide-white/5">
          <!-- Allowed -->
          <div class="flex items-center gap-4 px-6 py-3.5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-bold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-400">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Allowed
            </span>
            <code class="text-sm text-zinc-800 dark:text-zinc-200">calendar.listEvents</code>
            <span class="ml-auto hidden text-xs text-zinc-400 sm:block">Full access</span>
          </div>
          <!-- Constrained -->
          <div class="flex items-center gap-4 px-6 py-3.5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 text-[11px] font-bold text-amber-700 dark:bg-amber-500/10 dark:text-amber-400">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Constrained
            </span>
            <code class="text-sm text-zinc-800 dark:text-zinc-200">calendar.createEvent</code>
            <span class="ml-auto hidden text-xs text-zinc-400 sm:block">calendarId <code class="rounded bg-zinc-100 px-1.5 py-0.5 text-zinc-600 dark:bg-white/5 dark:text-zinc-300">must_equal "primary"</code></span>
          </div>
          <!-- Hidden 1 -->
          <div class="flex items-center gap-4 px-6 py-3.5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-zinc-100 px-2.5 py-1 text-[11px] font-bold text-zinc-500 dark:bg-white/5 dark:text-zinc-500">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              Hidden
            </span>
            <code class="text-sm text-zinc-400 line-through dark:text-zinc-600">gmail.send</code>
            <span class="ml-auto hidden text-xs text-zinc-400 sm:block">Tool doesn't exist to agent</span>
          </div>
          <!-- Hidden 2 -->
          <div class="flex items-center gap-4 px-6 py-3.5">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-zinc-100 px-2.5 py-1 text-[11px] font-bold text-zinc-500 dark:bg-white/5 dark:text-zinc-500">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              Hidden
            </span>
            <code class="text-sm text-zinc-400 line-through dark:text-zinc-600">calendar.deleteEvent</code>
            <span class="ml-auto hidden text-xs text-zinc-400 sm:block">Not implemented in code</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURES ═══ -->
    <section class="mx-auto mt-28 w-full max-w-6xl px-6 sm:mt-36">
      <div class="reveal text-center">
        <h2 class="font-[Fraunces] text-3xl font-bold italic text-zinc-900 dark:text-white sm:text-4xl">
          Why Gatelet?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-zinc-500 dark:text-zinc-400">
          Security guarantees that go beyond access control lists.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-5 sm:grid-cols-2">
        <!-- Feature 1: Defense in Depth -->
        <div class="reveal reveal-delay-1 glass flex flex-col rounded-2xl p-8 transition-transform duration-300 hover:scale-[1.015]">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 dark:bg-indigo-500/10">
            <svg class="h-5 w-5 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-zinc-900 dark:text-white">Defense in Depth</h3>
          <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Delete operations aren't just blocked &mdash;
            the code to execute them doesn't exist. Send and reply are disabled by default policy and hidden from the agent.
          </p>
        </div>

        <!-- Feature 2: Granular Constraints -->
        <div class="reveal reveal-delay-2 glass flex flex-col rounded-2xl p-8 transition-transform duration-300 hover:scale-[1.015]">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 dark:bg-emerald-500/10">
            <svg class="h-5 w-5 text-emerald-600 dark:text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-zinc-900 dark:text-white">Granular Constraints</h3>
          <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Set field-level constraints on any tool parameter. Restrict allowed values, enforce defaults,
            and mutate payloads before they reach upstream APIs &mdash; transparently.
          </p>
        </div>

        <!-- Feature 3: Hidden by Design -->
        <div class="reveal reveal-delay-3 glass flex flex-col rounded-2xl p-8 transition-transform duration-300 hover:scale-[1.015]">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-rose-50 dark:bg-rose-500/10">
            <svg class="h-5 w-5 text-rose-600 dark:text-rose-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
              <line x1="1" x2="23" y1="1" y2="23"/>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-zinc-900 dark:text-white">Hidden by Design</h3>
          <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Denied tools are never registered in MCP. Your agent can't request, discover, or be
            tricked into using what it doesn't know exists. No prompt injection can bypass this.
          </p>
        </div>

        <!-- Feature 4: Full Audit Trail -->
        <div class="reveal reveal-delay-4 glass flex flex-col rounded-2xl p-8 transition-transform duration-300 hover:scale-[1.015]">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-amber-50 dark:bg-amber-500/10">
            <svg class="h-5 w-5 text-amber-600 dark:text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/>
            </svg>
          </div>
          <h3 class="mb-2 text-lg font-bold text-zinc-900 dark:text-white">Full Audit Trail</h3>
          <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Every tool invocation is logged with the original request, policy decisions, parameter
            mutations, and the final response. Full observability by default.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ POLICY PREVIEW ═══ -->
    <section class="mx-auto mt-28 w-full max-w-4xl px-6 sm:mt-36">
      <div class="reveal text-center">
        <h2 class="font-[Fraunces] text-3xl font-bold italic text-zinc-900 dark:text-white sm:text-4xl">
          Declarative YAML policies
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-zinc-500 dark:text-zinc-400">
          Define exactly what each agent can access with human-readable configuration.
        </p>
      </div>

      <div class="reveal reveal-delay-1 mt-12 overflow-hidden rounded-2xl glass">
        <!-- Title bar -->
        <div class="flex items-center gap-3 border-b border-zinc-200 px-5 py-3 dark:border-white/5">
          <div class="flex gap-1.5">
            <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
            <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
            <div class="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700"></div>
          </div>
          <span class="text-xs font-medium text-zinc-400">gmail-policy.yaml</span>
        </div>
        <!-- YAML content with syntax colors -->
        <pre class="overflow-x-auto p-6 text-[13px] leading-[1.7] scrollbar-hide"><code><span class="text-zinc-500"># Gmail policy for your AI assistant</span>
<span class="text-indigo-600 dark:text-indigo-400">provider</span><span class="text-zinc-500">:</span> <span class="text-emerald-600 dark:text-emerald-400">google_gmail</span>
<span class="text-indigo-600 dark:text-indigo-400">account</span><span class="text-zinc-500">:</span> <span class="text-emerald-600 dark:text-emerald-400">me@gmail.com</span>

<span class="text-indigo-600 dark:text-indigo-400">operations</span><span class="text-zinc-500">:</span>
  <span class="text-indigo-600 dark:text-indigo-400">search</span><span class="text-zinc-500">:</span>
    <span class="text-indigo-600 dark:text-indigo-400">allow</span><span class="text-zinc-500">:</span> <span class="text-amber-600 dark:text-amber-400">true</span>

  <span class="text-indigo-600 dark:text-indigo-400">read_message</span><span class="text-zinc-500">:</span>
    <span class="text-indigo-600 dark:text-indigo-400">allow</span><span class="text-zinc-500">:</span> <span class="text-amber-600 dark:text-amber-400">true</span>
    <span class="text-indigo-600 dark:text-indigo-400">guards</span><span class="text-zinc-500">:</span>
      <span class="text-indigo-600 dark:text-indigo-400">block_subjects</span><span class="text-zinc-500">:</span>
