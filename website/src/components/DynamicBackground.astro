---
/**
 * Scrolling logo background — pure CSS, zero client JS.
 * Uses <symbol> + <use> so the logo SVG is defined once (~300 bytes)
 * and referenced 448 times (~56 bytes each) instead of 900 full SVG clones.
 * Animations are CSS transforms (GPU-composited).
 */
const rows = 14;
const logosPerRow = 16;
---

<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none select-none opacity-[0.03] dark:opacity-[0.03]" aria-hidden="true">
  <!-- Define logo symbol once -->
  <svg class="hidden" aria-hidden="true">
    <symbol id="bg-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
      <line x1="1" y1="5" x2="23" y2="5" />
      <line x1="1" y1="7" x2="23" y2="7" />
      <line x1="2" y1="7" x2="2" y2="22" />
      <line x1="8.5" y1="7" x2="8.5" y2="22" />
      <line x1="15.5" y1="7" x2="15.5" y2="22" />
      <line x1="22" y1="7" x2="22" y2="22" />
      <path d="M8.5 22V14a3.5 3.5 0 0 1 7 0v8" />
      <path d="M2 22v-4.5a3.25 3.25 0 0 1 6.5 0V22" />
      <path d="M15.5 22v-4.5a3.25 3.25 0 0 1 6.5 0V22" />
      <line x1="1" y1="22" x2="23" y2="22" />
    </symbol>
  </svg>

  <div class="flex flex-col gap-2 -mt-24 pb-4">
    {Array.from({ length: rows }).map((_, i) => {
      const reverse = i % 2 === 0;
      const speed = 60 + (i % 3) * 30;
      return (
        <div
          class={`flex whitespace-nowrap ${reverse ? 'marquee-reverse' : 'marquee'}`}
          style={`animation-duration: ${speed}s`}
        >
          {Array.from({ length: logosPerRow * 2 }).map(() => (
            <svg class="h-32 w-32 shrink-0 mr-4"><use href="#bg-logo"/></svg>
          ))}
        </div>
      );
    })}
  </div>
</div>
